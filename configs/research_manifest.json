{
  "data": {
    "root_dir": "./examples/datasets/mini_pdbbind",
    "dataset_format": "manifest_json",
    "manifest_path": "./examples/datasets/mini_pdbbind/manifest.json",
    "label_table_path": "./examples/datasets/mini_pdbbind/affinity_labels.csv",
    "max_ligand_atoms": 64,
    "max_pocket_atoms": 256,
    "pocket_cutoff_angstrom": 6.0,
    "max_examples": null,
    "batch_size": 2,
    "split_seed": 42,
    "val_fraction": 0.25,
    "test_fraction": 0.25,
    "stratify_by_measurement": true
  },
  "model": {
    "hidden_dim": 128,
    "num_slots": 8,
    "atom_vocab_size": 32,
    "bond_vocab_size": 8,
    "pocket_feature_dim": 24,
    "pair_feature_dim": 8
  },
  "training": {
    "learning_rate": 0.001,
    "max_steps": 4,
    "schedule": {
      "stage1_steps": 2,
      "stage2_steps": 4,
      "stage3_steps": 6
    },
    "loss_weights": {
      "alpha_task": 1.0,
      "beta_intra_red": 0.1,
      "gamma_probe": 0.2,
      "delta_leak": 0.05,
      "eta_gate": 0.05,
      "mu_slot": 0.05,
      "nu_consistency": 0.1
    },
    "checkpoint_dir": "./checkpoints",
    "checkpoint_every": 100,
    "log_every": 1,
    "affinity_weighting": "inverse_frequency"
  },
  "runtime": {
    "device": "cpu",
    "data_workers": 0
  }
}
