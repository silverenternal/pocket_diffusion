{
  "research": {
    "data": {
      "root_dir": ".",
      "dataset_format": "manifest_json",
      "manifest_path": "./data/pdbbindpp-2020/manifest.json",
      "label_table_path": "./data/pdbbindpp-2020/affinity_labels.csv",
      "parsing_mode": "lightweight",
      "max_ligand_atoms": 96,
      "max_pocket_atoms": 512,
      "pocket_cutoff_angstrom": 7.5,
      "max_examples": 512,
      "batch_size": 8,
      "split_seed": 42,
      "val_fraction": 0.15,
      "test_fraction": 0.15,
      "stratify_by_measurement": true,
      "quality_filters": {
        "min_label_coverage": null,
        "max_fallback_fraction": 0.0,
        "max_ligand_atoms": 96,
        "max_pocket_atoms": 512,
        "require_source_structure_provenance": true
      },
      "generation_target": {
        "atom_mask_ratio": 0.15,
        "coordinate_noise_std": 0.08,
        "corruption_seed": 1337,
        "rollout_steps": 4,
        "min_rollout_steps": 2,
        "stop_probability_threshold": 0.82,
        "coordinate_step_scale": 0.8,
        "rollout_eval_step_weight_decay": 0.9,
        "rollout_mode": "momentum_refine",
        "coordinate_momentum": 0.55,
        "atom_momentum": 0.4,
        "atom_commit_temperature": 0.9,
        "max_coordinate_delta_norm": 1.5,
        "stop_delta_threshold": 0.02,
        "stop_patience": 2,
        "sampling_seed": 4242,
        "sampling_temperature": 0.0,
        "sampling_top_k": 0,
        "sampling_top_p": 1.0,
        "coordinate_sampling_noise_std": 0.0,
        "pocket_guidance_scale": 1.0,
        "generation_mode": "flow_refinement"
      }
    },
    "model": {
      "hidden_dim": 128,
      "num_slots": 8,
      "atom_vocab_size": 32,
      "bond_vocab_size": 8,
      "pocket_feature_dim": 24,
      "pair_feature_dim": 8,
      "interaction_mode": "transformer",
      "interaction_ff_multiplier": 2,
      "interaction_tuning": {
        "gate_temperature": 1.35,
        "gate_bias": -0.1,
        "attention_residual_scale": 0.7,
        "ffn_residual_scale": 0.35,
        "transformer_pre_norm": true,
        "geometry_attention_bias_scale": 1.0
      }
    },
    "generation_method": {
      "active_method": "flow_matching",
      "primary_backend": {
        "backend_id": "flow_matching",
        "family": "flow_matching",
        "trainable": true,
        "sampling_steps": 20
      },
      "comparison_methods": [
        "conditioned_denoising",
        "flow_matching",
        "calibrated_reranker"
      ],
      "candidate_count": 3,
      "enable_comparison_runner": true,
      "flow_matching": {
        "steps": 20,
        "noise_scale": 0.15,
        "integration_method": "euler",
        "geometry_only": false,
        "use_corrupted_x0": true,
        "multi_modal": {
          "enabled_branches": [
            "geometry",
            "atom_type",
            "bond",
            "topology",
            "pocket_context"
          ],
          "branch_loss_weights": {
            "geometry": 1.0,
            "atom_type": 0.3,
            "bond": 0.45,
            "topology": 0.45,
            "pocket_context": 0.2,
            "synchronization": 0.15
          },
          "branch_schedule": {
            "geometry": {
              "enabled": true,
              "start_step": 0,
              "warmup_steps": 0,
              "final_weight_multiplier": 1.0
            },
            "atom_type": {
              "enabled": true,
              "start_step": 1,
              "warmup_steps": 2,
              "final_weight_multiplier": 1.0
            },
            "bond": {
              "enabled": true,
              "start_step": 1,
              "warmup_steps": 2,
              "final_weight_multiplier": 1.0
            },
            "topology": {
              "enabled": true,
              "start_step": 2,
              "warmup_steps": 2,
              "final_weight_multiplier": 1.0
            },
            "pocket_context": {
              "enabled": true,
              "start_step": 2,
              "warmup_steps": 2,
              "final_weight_multiplier": 1.0
            },
            "synchronization": {
              "enabled": true,
              "start_step": 3,
              "warmup_steps": 2,
              "final_weight_multiplier": 1.0
            }
          },
          "target_alignment_policy": "hungarian_distance",
          "allow_zero_weight_branch_ablation": false,
          "claim_full_molecular_flow": true
        }
      }
    },
    "training": {
      "learning_rate": 0.001,
      "max_steps": 8,
      "schedule": {
        "stage1_steps": 2,
        "stage2_steps": 4,
        "stage3_steps": 6
      },
      "loss_weights": {
        "alpha_primary": 1.0,
        "beta_intra_red": 0.05,
        "gamma_probe": 0.02,
        "delta_leak": 0.05,
        "eta_gate": 0.05,
        "mu_slot": 0.05,
        "nu_consistency": 0.1,
        "rho_pocket_contact": 0.05,
        "lambda_pocket_pair_distance": 0.02,
        "sigma_pocket_clash": 0.02,
        "omega_pocket_shape_complementarity": 0.02,
        "tau_pocket_envelope": 0.02,
        "kappa_pocket_prior": 0.01,
        "upsilon_valence_guardrail": 0.03,
        "phi_bond_length_guardrail": 0.02,
        "chi_nonbonded_distance_guardrail": 0.01,
        "psi_angle_guardrail": 0.01
      },
      "pharmacophore_probes": {
        "enable_ligand_role_probe": true,
        "enable_pocket_role_probe": true,
        "enable_topology_to_pocket_role_leakage": true,
        "enable_geometry_to_pocket_role_leakage": true,
        "enable_pocket_to_ligand_role_leakage": true,
        "leakage_margin": 0.05
      },
      "chemistry_warmup": {
        "pocket_envelope_start_stage": 2,
        "pocket_prior_start_stage": 2,
        "valence_guardrail_start_stage": 2,
        "bond_length_guardrail_start_stage": 2,
        "nonbonded_distance_guardrail_start_stage": 2,
        "angle_guardrail_start_stage": 2,
        "pharmacophore_probe_start_stage": 3,
        "pharmacophore_leakage_start_stage": 3
      },
      "objective_scale_diagnostics": {
        "family_budget_cap_fraction": 0.35,
        "family_budget_action": "clamp"
      },
      "checkpoint_dir": "./checkpoints/multi_seed_pdbbindpp_flow/base",
      "checkpoint_every": 100,
      "log_every": 1,
      "primary_objective": "flow_matching",
      "flow_matching_loss_weight": 1.0,
      "affinity_weighting": "inverse_frequency"
    },
    "runtime": {
      "device": "cpu",
      "data_workers": 0,
      "tch_intra_op_threads": null,
      "tch_inter_op_threads": null
    }
  },
  "surface_label": "multi_seed_pdbbindpp_flow",
  "ablation": {
    "disable_slots": false,
    "disable_cross_attention": false,
    "disable_probes": false,
    "disable_leakage": false,
    "disable_geometry_interaction_bias": false,
    "disable_rollout_pocket_guidance": false,
    "disable_candidate_repair": false,
    "primary_objective_override": null,
    "interaction_mode_override": null,
    "variant_label": "multi_seed_pdbbindpp_flow_base"
  },
  "external_evaluation": {
    "chemistry_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/rdkit_validity_backend.py"
      ]
    },
    "docking_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/pocket_contact_backend.py",
        "--mode",
        "docking"
      ]
    },
    "pocket_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/pocket_contact_backend.py",
        "--mode",
        "compatibility"
      ]
    }
  },
  "multi_seed": {
    "enabled": true,
    "seeds": [17, 42, 101],
    "artifact_root_dir": "./checkpoints/multi_seed_pdbbindpp_flow"
  }
}
