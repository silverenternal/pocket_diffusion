{
  "research": {
    "data": {
      "root_dir": "./data/PDBbind_v2020_refined",
      "dataset_format": "pdbbind_like_dir",
      "manifest_path": null,
      "label_table_path": null,
      "max_ligand_atoms": 64,
      "max_pocket_atoms": 256,
      "pocket_cutoff_angstrom": 5.0,
      "max_examples": null,
      "batch_size": 2,
      "split_seed": 42,
      "val_fraction": 0.2,
      "test_fraction": 0.2,
      "stratify_by_measurement": false,
      "generation_target": {
        "atom_mask_ratio": 0.15,
        "coordinate_noise_std": 0.08,
        "corruption_seed": 1337,
        "rollout_steps": 4,
        "min_rollout_steps": 2,
        "stop_probability_threshold": 0.82,
        "coordinate_step_scale": 0.8,
        "rollout_eval_step_weight_decay": 0.9,
        "rollout_mode": "momentum_refine",
        "coordinate_momentum": 0.55,
        "atom_momentum": 0.4,
        "atom_commit_temperature": 0.9,
        "max_coordinate_delta_norm": 1.5,
        "stop_delta_threshold": 0.02,
        "stop_patience": 2
      }
    },
    "model": {
      "hidden_dim": 128,
      "num_slots": 8,
      "atom_vocab_size": 32,
      "bond_vocab_size": 8,
      "pocket_feature_dim": 24,
      "pair_feature_dim": 8,
      "interaction_mode": "transformer",
      "interaction_ff_multiplier": 2,
      "interaction_tuning": {
        "gate_temperature": 1.0,
        "gate_bias": 0.1,
        "attention_residual_scale": 0.75,
        "ffn_residual_scale": 0.25,
        "transformer_pre_norm": true
      }
    },
    "training": {
      "learning_rate": 0.001,
      "max_steps": 4,
      "schedule": {
        "stage1_steps": 1,
        "stage2_steps": 2,
        "stage3_steps": 4
      },
      "loss_weights": {
        "alpha_task": 1.0,
        "beta_intra_red": 0.1,
        "gamma_probe": 0.2,
        "delta_leak": 0.05,
        "eta_gate": 0.05,
        "mu_slot": 0.05,
        "nu_consistency": 0.1
      },
      "checkpoint_dir": "./checkpoints/harder_pressure",
      "checkpoint_every": 100,
      "log_every": 1,
      "primary_objective": "conditioned_denoising",
      "affinity_weighting": "inverse_frequency"
    },
    "runtime": {
      "device": "cpu",
      "data_workers": 0
    }
  },
  "surface_label": "harder_pressure",
  "ablation": {
    "disable_slots": false,
    "disable_cross_attention": false,
    "disable_probes": false,
    "disable_leakage": false,
    "variant_label": "harder_pressure_base"
  },
  "external_evaluation": {
    "chemistry_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/rdkit_validity_backend.py"
      ]
    },
    "docking_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/pocket_contact_backend.py",
        "--mode",
        "docking"
      ]
    },
    "pocket_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/pocket_contact_backend.py",
        "--mode",
        "compatibility"
      ]
    }
  },
  "ablation_matrix": {
    "enabled": true,
    "include_surrogate_objective": true,
    "include_conditioned_denoising": true,
    "include_disable_slots": true,
    "include_disable_cross_attention": true,
    "include_disable_probes": false,
    "include_lightweight_interaction": true,
    "include_transformer_interaction": true
  }
}
