      "log_every": 1,
      "primary_objective": "conditioned_denoising",
      "affinity_weighting": "inverse_frequency"
    },
    "runtime": {
      "device": "cpu",
      "data_workers": 0
    }
  },
  "surface_label": "claim_matrix",
