      "loss_weights": {
        "alpha_task": 1.0,
        "beta_intra_red": 0.1,
        "gamma_probe": 0.2,
        "delta_leak": 0.05,
        "eta_gate": 0.05,
        "mu_slot": 0.05,
        "nu_consistency": 0.1
