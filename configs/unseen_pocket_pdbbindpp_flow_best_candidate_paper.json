{
  "research": {
    "data": {
      "root_dir": ".",
      "dataset_format": "manifest_json",
      "manifest_path": "./data/pdbbindpp-2020/manifest.json",
      "label_table_path": "./data/pdbbindpp-2020/affinity_labels.csv",
      "max_ligand_atoms": 96,
      "max_pocket_atoms": 512,
      "pocket_cutoff_angstrom": 7.5,
      "max_examples": 1024,
      "batch_size": 32,
      "split_seed": 42,
      "val_fraction": 0.15,
      "test_fraction": 0.15,
      "stratify_by_measurement": true,
      "quality_filters": {
        "min_label_coverage": null,
        "max_fallback_fraction": 0.0,
        "max_ligand_atoms": 96,
        "max_pocket_atoms": 512,
        "require_source_structure_provenance": true
      },
      "generation_target": {
        "atom_mask_ratio": 0.15,
        "coordinate_noise_std": 0.08,
        "corruption_seed": 1337,
        "rollout_steps": 4,
        "min_rollout_steps": 2,
        "stop_probability_threshold": 0.82,
        "coordinate_step_scale": 0.8,
        "rollout_eval_step_weight_decay": 0.9,
        "rollout_mode": "momentum_refine",
        "coordinate_momentum": 0.55,
        "atom_momentum": 0.4,
        "atom_commit_temperature": 0.9,
        "max_coordinate_delta_norm": 1.5,
        "stop_delta_threshold": 0.02,
        "stop_patience": 2,
        "pocket_guidance_scale": 1.2,
        "generation_mode": "flow_refinement",
        "sampling_seed": 4242
      }
    },
    "model": {
      "hidden_dim": 128,
      "num_slots": 8,
      "atom_vocab_size": 32,
      "bond_vocab_size": 8,
      "pocket_feature_dim": 24,
      "pair_feature_dim": 8,
      "topology_encoder": {
        "kind": "typed_message_passing",
        "message_passing_layers": 3,
        "residual_scale": 0.5,
        "normalize_messages": true,
        "bond_type_vocab_size": 8
      },
      "geometry_encoder": {
        "operator": "local_frame_pair_message",
        "distance_kernel_count": 8,
        "distance_kernel_max_distance": 8.0,
        "distance_kernel_gamma": 0.75,
        "residual_scale": 0.5
      },
      "pocket_encoder": {
        "kind": "ligand_relative_local_frame",
        "message_passing_layers": 3,
        "neighbor_radius": 6.0,
        "residual_scale": 0.5
      },
      "flow_velocity_head": {
        "kind": "atom_pocket_cross_attention",
        "gate_initial_bias": -0.5
      },
      "pairwise_geometry": {
        "enabled": true,
        "radius": 4.5,
        "max_neighbors": 16,
        "residual_scale": 0.1
      },
      "decoder_conditioning": {
        "kind": "local_atom_slot_attention",
        "local_gate_initial_bias": -0.5
      },
      "interaction_mode": "transformer",
      "modality_focus": "all",
      "interaction_tuning": {
        "gate_mode": "path_scalar",
        "gate_temperature": 2.5,
        "gate_bias": 0.3,
        "attention_residual_scale": 0.75,
        "ffn_residual_scale": 0.35,
        "transformer_pre_norm": true,
        "geometry_attention_bias_scale": 1.15,
        "chemistry_role_attention_bias_scale": 0.35,
        "gate_regularization_path_weights": [
          {
            "path": "geo_from_pocket",
            "weight": 0.5
          },
          {
            "path": "pocket_from_geo",
            "weight": 0.5
          },
          {
            "path": "topo_from_pocket",
            "weight": 0.75
          },
          {
            "path": "pocket_from_topo",
            "weight": 0.75
          }
        ]
      }
    },
    "generation_method": {
      "active_method": "flow_matching",
      "primary_backend": {
        "backend_id": "flow_matching",
        "family": "flow_matching",
        "trainable": true,
        "sampling_steps": 20
      },
      "comparison_methods": [
        "conditioned_denoising",
        "flow_matching",
        "calibrated_reranker"
      ],
      "candidate_count": 3,
      "enable_comparison_runner": true,
      "flow_matching": {
        "steps": 20,
        "noise_scale": 0.15,
        "integration_method": "euler",
        "geometry_only": false,
        "use_corrupted_x0": true,
        "multi_modal": {
          "enabled_branches": [
            "geometry",
            "atom_type",
            "bond",
            "topology",
            "pocket_context"
          ],
          "branch_loss_weights": {
            "geometry": 1.0,
            "atom_type": 0.4,
            "bond": 0.7,
            "topology": 0.7,
            "pocket_context": 0.45,
            "synchronization": 0.3
          },
          "branch_schedule": {
            "geometry": {
              "enabled": true,
              "start_step": 0,
              "warmup_steps": 0,
              "final_weight_multiplier": 1.0
            },
            "atom_type": {
              "enabled": true,
              "start_step": 1,
              "warmup_steps": 4,
              "final_weight_multiplier": 1.0
            },
            "bond": {
              "enabled": true,
              "start_step": 1,
              "warmup_steps": 4,
              "final_weight_multiplier": 1.0
            },
            "topology": {
              "enabled": true,
              "start_step": 2,
              "warmup_steps": 4,
              "final_weight_multiplier": 1.0
            },
            "pocket_context": {
              "enabled": true,
              "start_step": 4,
              "warmup_steps": 6,
              "final_weight_multiplier": 1.0
            },
            "synchronization": {
              "enabled": true,
              "start_step": 6,
              "warmup_steps": 6,
              "final_weight_multiplier": 1.0
            }
          },
          "target_alignment_policy": "hungarian_distance",
          "allow_zero_weight_branch_ablation": false,
          "claim_full_molecular_flow": true
        }
      }
    },
    "preference_alignment": {
      "enable_profile_extraction": true,
      "enable_pair_construction": true,
      "enable_preference_reranking": true,
      "max_pairs_per_example": 256,
      "min_soft_margin": 0.0,
      "max_clash_fraction": 0.1,
      "min_strict_pocket_fit_score": 0.35,
      "missing_artifacts_mean_unavailable": true
    },
    "training": {
      "learning_rate": 0.001,
      "max_steps": 100,
      "schedule": {
        "stage1_steps": 20,
        "stage2_steps": 50,
        "stage3_steps": 100
      },
      "loss_weights": {
        "alpha_task": 1.0,
        "beta_intra_red": 0.05,
        "gamma_probe": 0.06,
        "delta_leak": 0.05,
        "eta_gate": 0.015,
        "mu_slot": 0.05,
        "nu_consistency": 0.12,
        "rho_pocket_contact": 0.07,
        "lambda_pocket_pair_distance": 0.05,
        "sigma_pocket_clash": 0.03,
        "omega_pocket_shape_complementarity": 0.03,
        "tau_pocket_envelope": 0.04,
        "kappa_pocket_prior": 0.01,
        "upsilon_valence_guardrail": 0.03,
        "phi_bond_length_guardrail": 0.02,
        "chi_nonbonded_distance_guardrail": 0.01,
        "psi_angle_guardrail": 0.01
      },
      "pharmacophore_probes": {
        "enable_ligand_role_probe": true,
        "enable_pocket_role_probe": true,
        "enable_topology_to_pocket_role_leakage": true,
        "enable_geometry_to_pocket_role_leakage": true,
        "enable_pocket_to_ligand_role_leakage": true,
        "leakage_margin": 0.05
      },
      "chemistry_warmup": {
        "pocket_envelope_start_stage": 2,
        "pocket_prior_start_stage": 2,
        "valence_guardrail_start_stage": 2,
        "bond_length_guardrail_start_stage": 2,
        "nonbonded_distance_guardrail_start_stage": 2,
        "angle_guardrail_start_stage": 2,
        "pharmacophore_probe_start_stage": 3,
        "pharmacophore_leakage_start_stage": 3
      },
      "sparse_topology_calibration": {
        "enabled": true,
        "start_step": 4,
        "warmup_steps": 16,
        "probe_weight": 0.0075,
        "flow_weight": 0.03,
        "rollout_weight": 0.02,
        "min_rate_scale": 0.05,
        "max_raw_loss": 8.0,
        "confidence_pressure_weight": 0.15,
        "confidence_pressure_max_loss": 10.0,
        "degree_alignment_weight": 0.12,
        "probe_degree_alignment_weight": 0.055,
        "degree_alignment_max_loss": 6.0,
        "native_score_calibration_weight": 0.2,
        "native_score_calibration_max_loss": 6.0,
        "native_score_threshold": 0.6
      },
      "objective_scale_diagnostics": {
        "family_budget_cap_fraction": 0.35,
        "family_budget_action": "clamp"
      },
      "rollout_training": {
        "enabled": true,
        "warmup_step": 2,
        "rollout_steps": 2,
        "detach_policy": "detach_between_steps",
        "max_batch_examples": 4,
        "allowed_generation_modes": [
          "flow_refinement"
        ],
        "atom_validity_weight": 0.12,
        "bond_consistency_weight": 0.08,
        "pocket_contact_weight": 0.08,
        "clash_weight": 0.1,
        "endpoint_consistency_weight": 0.15
      },
      "checkpoint_dir": "./checkpoints/pdbbindpp_flow_best_candidate_paper",
      "checkpoint_every": 100,
      "log_every": 1,
      "primary_objective": "flow_matching",
      "flow_matching_loss_weight": 1.0,
      "affinity_weighting": "inverse_frequency"
    },
    "runtime": {
      "device": "cpu",
      "data_workers": 0
    }
  },
  "surface_label": "pdbbindpp_flow_best_candidate",
  "ablation": {
    "disable_slots": false,
    "disable_cross_attention": false,
    "disable_probes": false,
    "disable_leakage": false
  },
  "external_evaluation": {
    "chemistry_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/rdkit_validity_backend.py"
      ]
    },
    "docking_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/pocket_contact_backend.py",
        "--mode",
        "docking"
      ]
    },
    "pocket_backend": {
      "enabled": true,
      "executable": "python3",
      "args": [
        "./tools/pocket_contact_backend.py",
        "--mode",
        "compatibility"
      ]
    }
  },
  "performance_gates": {
    "min_validation_examples_per_second": 1.0,
    "min_test_examples_per_second": 1.0,
    "max_validation_memory_mb": 4096.0,
    "max_test_memory_mb": 4096.0
  }
}
