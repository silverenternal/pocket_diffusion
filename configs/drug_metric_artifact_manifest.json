      },
      {
        "metric_name": "logp",
        "domain": "DrugLikeness",
        "direction": "HigherIsBetter",
        "primary_claim_metric": false
      },
      {
        "metric_name": "sa_score",
        "domain": "DrugLikeness",
        "direction": "LowerIsBetter",
        "primary_claim_metric": true
