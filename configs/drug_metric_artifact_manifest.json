  "artifact_registry": [
    {
      "path": "artifacts/evidence/q2/candidate_metrics_q2_ours_public100.jsonl",
      "artifact_role": "q2.candidate_metrics",
      "provenance_command": "python3 tools/merge_candidate_metric_backends.py --input-dir checkpoints/q2_ours_public100 --output-jsonl artifacts/evidence/q2/candidate_metrics_q2_ours_public100.jsonl",
      "required": true,
      "producer": "merge_candidate_metric_backends.py",
      "validation_consumer": ["validation_suite.validate_q2_artifacts"]
    },
    {
      "path": "artifacts/evidence/q2/q2_proxy_backend_correlation.json",
      "artifact_role": "q2.proxy_backend_correlation",
      "provenance_command": "python3 tools/correlation_table.py --candidate-metrics artifacts/evidence/q2/candidate_metrics_q2_ours_public100.jsonl --output-json artifacts/evidence/q2/q2_proxy_backend_correlation.json",
      "required": true,
      "producer": "correlation_table.py",
      "validation_consumer": ["validation_suite.validate_q2_artifacts"]
    },
    {
      "path": "artifacts/evidence/q2/postprocessing_failure_audit.json",
      "artifact_role": "q2.postprocessing_failure_audit",
      "provenance_command": "python3 tools/public_baseline_postprocess_layers.py --candidate-metrics artifacts/evidence/q2/candidate_metrics_q2_ours_public100.jsonl --output-json artifacts/evidence/q2/postprocessing_failure_audit.json",
      "required": true,
      "producer": "public_baseline_postprocess_layers.py",
      "validation_consumer": ["validation_suite.validate_q2_artifacts"]
    },
    {
      "path": "configs/q2_ours_vs_public_baselines_summary.json",
      "artifact_role": "q2.ours_vs_public_baselines_summary",
      "provenance_command": "python3 tools/public_baseline_method_comparison.py --candidate-metrics artifacts/evidence/q2/candidate_metrics_q2_ours_public100.jsonl --summary-json configs/q2_ours_vs_public_baselines_summary.json",
      "required": true,
      "producer": "public_baseline_method_comparison.py",
      "validation_consumer": ["validation_suite.validate_q2_artifacts"]
    },
    {
      "path": "configs/q2_postprocessing_ablation_summary.json",
      "artifact_role": "q2.postprocessing_ablation_summary",
      "provenance_command": "python3 tools/postprocessing_ablation_summary.py --output-json configs/q2_postprocessing_ablation_summary.json",
      "required": true,
      "producer": "postprocessing_ablation_summary.py",
      "validation_consumer": ["validation_suite.validate_q2_artifacts", "validation_suite.validate_coordinate_frame_consistency"]
    },
    {
      "path": "configs/q2_claim_contract.json",
      "artifact_role": "q2.claim_contract",
      "provenance_command": "python3 tools/claim_regression_gate.py --output-json configs/q2_claim_contract.json",
      "required": true,
      "producer": "claim_regression_gate.py",
      "validation_consumer": ["validation_suite.validate_q2_artifacts"]
    },
    {
      "path": "configs/q3_rotation_consistency_report.json",
      "artifact_role": "q3.rotation_consistency_report",
      "provenance_command": "python3 tools/q3_model_improvement_leaderboard.py --rotation-report configs/q3_rotation_consistency_report.json",
      "required": false,
      "producer": "q3_model_improvement_leaderboard.py",
      "validation_consumer": ["validation_suite.validate_q3_non_degradation_gate"]
    },
    {
      "path": "configs/q3_model_improvement_leaderboard.json",
      "artifact_role": "q3.model_improvement_leaderboard",
      "provenance_command": "python3 tools/q3_model_improvement_leaderboard.py --output-json configs/q3_model_improvement_leaderboard.json",
      "required": false,
      "producer": "q3_model_improvement_leaderboard.py",
      "validation_consumer": ["validation_suite.validate_q3_non_degradation_gate"]
    },
    {
      "path": "configs/q3_non_degradation_gate.json",
      "artifact_role": "q3.non_degradation_gate",
      "provenance_command": "python3 tools/claim_regression_gate.py --kind q3 --output-json configs/q3_non_degradation_gate.json",
      "required": false,
      "producer": "claim_regression_gate.py",
      "validation_consumer": ["validation_suite.validate_q3_non_degradation_gate"]
    }
  ],
  "phase_artifacts": {
    "q2": [
      "artifacts/evidence/q2/candidate_metrics_q2_ours_public100.jsonl",
      "artifacts/evidence/q2/q2_proxy_backend_correlation.json",
      "artifacts/evidence/q2/postprocessing_failure_audit.json"
    ]
