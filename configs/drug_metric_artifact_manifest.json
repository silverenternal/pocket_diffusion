{
  "schema_version": 1,
  "artifact_root": "artifacts/evidence",
  "purpose": "Keep drug-metric evidence grouped by research phase while preserving validation and paper-claim references.",
  "claim_provenance_contract": {
    "schema_version": 1,
    "record_shape": "Each claim-facing metric record must carry value, provenance, and status fields.",
    "values": [
      {
        "value": "heuristic",
        "claim_use": "diagnostic only; cannot be promoted to backend-supported, docking-supported, or experimental evidence"
      },
      {
        "value": "backend_supported",
        "claim_use": "supported by an available non-docking backend with explicit backend_name, status, and coverage metrics"
      },
      {
        "value": "docking_supported",
        "claim_use": "supported by an available docking backend with explicit backend_name, status, and coverage metrics"
      },
      {
        "value": "experimental",
        "claim_use": "reserved for explicit experimental_evidence records; currently unavailable in this repository"
      },
      {
        "value": "unavailable",
        "claim_use": "must use value=null; do not substitute zero or heuristic fallback values"
      }
    ],
    "backend_metric_requirements": [
      "backend_name",
      "status",
      "backend_examples_scored or candidate_metric_rows or backend_missing_structure_fraction"
    ],
    "forbidden_promotions": [
      "heuristic_to_backend_supported",
      "heuristic_to_docking_supported",
      "heuristic_to_experimental",
      "unavailable_to_zero"
    ]
  },
  "metric_contract": {
    "schema_version": 2,
    "rust_wrapper": "pocket_diffusion::models::DrugMetricPanel",
    "domains": [
      "Docking",
      "DrugLikeness",
      "ChemistryValidity",
      "PocketCompatibility",
      "BackendQuality",
      "Auxiliary"
    ],
    "metrics": [
